# ========== ГЛАВНОЕ: ЗАГРУЖАЕМ ТОЛЬКО assignments/ ==========
# Исключаем всё в корне кроме нужных файлов
/*
!/assignments/
!.gitignore
!.gitattributes
!.github

# ========== ИСКЛЮЧЕНИЯ ВНУТРИ assignments/ ==========
# IDE конфиги
assignments/**/.idea/
assignments/**/.vscode/
assignments/**/*.iml

# Артефакты сборки C++
assignments/**/build/
assignments/**/cmake-build-*/
assignments/**/CMakeCache.txt
assignments/**/CMakeFiles/
assignments/**/*.o
assignments/**/*.obj
assignments/**/*.a
assignments/**/*.lib
assignments/**/*.exe
assignments/**/*.out

# Python виртуальные окружения и кеш
assignments/**/.venv/
assignments/**/venv/
assignments/**/__pycache__/
assignments/**/*.pyc
assignments/**/*.pyo
assignments/**/*.egg-info/

# ОС файлы
assignments/**/.DS_Store
assignments/**/Thumbs.db
assignments/**/desktop.ini

# Логи
assignments/**/*.log

